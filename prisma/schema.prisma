generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String       @id
  email              String       @unique
  name               String?
  image              String?
  plan               Plan         @default(FREE)
  isAdmin            Boolean      @default(false)
  razorpayCustomerId String?
  createdAt          DateTime     @default(now())
  automations        Automation[]
  stores             Store[]
  payments           Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  plan       Plan
  amount     Int
  currency   String   @default("INR")
  status     String
  razorpayId String?
  createdAt  DateTime @default(now())
}

model Store {
  id          String       @id @default(cuid())
  name        String
  platform    String
  url         String
  apiKey      String?
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  automations Automation[]
  createdAt   DateTime     @default(now())
}

model Automation {
  id        String          @id @default(cuid())
  name      String
  type      AutomationType
  status    Status          @default(ACTIVE)
  trigger   Json
  action    Json
  runCount  Int             @default(0)
  lastRun   DateTime?
  userId    String
  storeId   String
  user      User            @relation(fields: [userId], references: [id])
  store     Store           @relation(fields: [storeId], references: [id])
  logs      AutomationLog[]
  createdAt DateTime        @default(now())
}

model AutomationLog {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id])
  status       String
  message      String
  createdAt    DateTime   @default(now())
}

enum Plan {
  FREE
  STARTER
  GROWTH
  PRO
}

enum Status {
  ACTIVE
  PAUSED
  DRAFT
}

enum AutomationType {
  ABANDONED_CART
  LOW_STOCK_ALERT
  WEEKLY_REPORT
  AUTO_REPLY
  ORDER_FOLLOWUP
  REVIEW_REQUEST
}
